<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<config xmlns="http://www.hybris.com/schema/cockpitng/config"
        xmlns:explorer-tree="http://www.hybris.com/schema/cockpitng/config/explorertree"
        xmlns:editorArea="http://www.hybris.com/schema/cockpitng/config/editorarea"
        xmlns:list-view="http://www.hybris.com/schema/cockpitng/config/listview"
        xmlns:advanced-search="http://www.hybris.com/schema/cockpitng/config/advancedsearch"
        xmlns:y="http://www.hybris.com/cockpit/config/hybris"
        xmlns:na="http://www.hybris.com/cockpitng/config/notifications">

    <context merge-by="type" type="Consignment" component="editorareaactions" principal="admingroup">
        <y:actions>
            <y:group qualifier="common">
                <y:label>actiongroup.common</y:label>
                <y:action action-id="org.training.backoffice.actions.confirmPickupAction"
                          property="currentObject"/>
            </y:group>
        </y:actions>
    </context>

    <context type="OrderTrackingEmailProcess" component="advanced-search"
             merge-by="type" principal="admingroup">
        <advanced-search:advanced-search>
            <advanced-search:field-list>
                <advanced-search:field qualifier="code" selected="true"/>
                <advanced-search:field qualifier="email" selected="true"/>
                <advanced-search:field qualifier="fullname" selected="true"/>
                <advanced-search:field qualifier="state" selected="true"/>
            </advanced-search:field-list>
        </advanced-search:advanced-search>
    </context>

    <context type="OrderTrackingEmailProcess" component="listview"
             merge-by="type" principal="admingroup">
        <list-view:list-view>
            <list-view:column qualifier="code"/>
            <list-view:column qualifier="email"/>
            <list-view:column qualifier="fullname"/>
            <list-view:column qualifier="state"/>
        </list-view:list-view>
    </context>

    <context type="OrderTrackingEmailProcess" component="editorarea"
             merge-by="type" principal="admingroup">
        <editorArea:editorArea>
            <editorArea:tab name="training.tab.tracking">
                <editorArea:section name="training.section.trackingdetails">
                    <editorArea:attribute qualifier="code" readonly="true"/>
                    <editorArea:attribute qualifier="email"/>
                    <editorArea:attribute qualifier="fullname"/>
                    <editorArea:attribute qualifier="frontendTemplateName"/>
                    <editorArea:attribute qualifier="state" readonly="true"/>
                </editorArea:section>
            </editorArea:tab>
        </editorArea:editorArea>
    </context>

    <context component="explorer-tree" merge-by="module">
        <explorer-tree:explorer-tree>
            <explorer-tree:navigation-node id="hmc_treenode_orders">
                <explorer-tree:type-node code="OrderTrackingEmailProcess"
                                         id="myOrderTrackingNode"
                                         principal="admingroup"/>
            </explorer-tree:navigation-node>
        </explorer-tree:explorer-tree>
    </context>

    <context component="notification-area">
        <na:notification-area>
            <na:notifications eventType="trainingbackoffice.confirmpickup.event"
                              level="SUCCESS">
                <na:message>hmc.action.confirmpickup.success</na:message>
            </na:notifications>
            <na:notifications eventType="trainingbackoffice.confirmpickup.event"
                              level="FAILURE">
                <na:message>hmc.action.confirmpickup.failure</na:message>
            </na:notifications>
        </na:notification-area>
    </context>

</config>