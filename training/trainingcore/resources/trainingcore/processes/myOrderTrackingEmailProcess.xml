<process xmlns="http://www.hybris.de/xsd/processdefinition"
         start="generateEmail"
         name="orderTrackingProcess"
         processClass="org.training.core.model.OrderTrackingEmailProcessModel">

    <contextParameter name="frontendTemplateName"
                      use="optional"
                      type="java.lang.String"/>
    <action id="generateEmail" bean="myGenerateEmail">
        <transition name="OK" to="sendEmail"/>
        <transition name="NOK" to="failed"/>
    </action>

    <action id="sendEmail" bean="sendEmail">
        <transition name="OK" to="success"/>
        <transition name="NOK" to="failed"/>
    </action>

    <end id="success" state="SUCCEEDED"/>
    <end id="failed" state="FAILED"/>

</process>
