<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context.xsd">

      <context:component-scan base-package="org.training.controllers"/>

    <bean parent="fieldSetLevelMapping" id="TRACKING_VehicleItemMapping">
        <property name="dtoClass" value="org.training.dto.VehicleWsDto"/>
        <property name="levelMapping">
            <map>
                <entry key="BASIC"   value="code,name"/>
                <entry key="DEFAULT" value="name,cc"/>
                <entry key="FULL"    value="code,name,cc,hp,topSpeed"/>
                <entry key="CUSTOM"  value="cc,hp"/>
            </map>
        </property>
    </bean>

    <bean parent="fieldSetLevelMapping" id="TRACKING_VehicleTrackingMapping">
        <property name="dtoClass" value="org.training.dto.VehicleTrackingWsDto"/>
        <property name="levelMapping">
            <map>
                <entry key="BASIC"   value="vehicles(BASIC)"/>
                <entry key="DEFAULT" value="vehicles(DEFAULT)"/>
                <entry key="FULL"    value="vehicles(FULL)"/>
                <entry key="CUSTOM">
                    <value>vehicles(cc,hp)</value>
                </entry>
            </map>
        </property>
    </bean>
</beans>